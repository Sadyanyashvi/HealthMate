<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fitnessbg"
    tools:context=".FitnessFragment">

    <TextView
        android:layout_width="216dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="100dp"
        android:layout_marginTop="80dp"
        android:text="Fitness Tracking and Recommendations"
        android:textStyle="bold"
        android:textColor="#0B0A0A"
        android:textSize="20dp" />

    <TextView

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="80dp"
        android:layout_marginRight="80dp"
        android:layout_marginTop="180dp"
        android:text="The app tracks users' fitness progress and provides personalized workout plans based on their fitness level and goals. Users can also connect with friends and share their fitness progress and goals."
        android:textColor="#0E0D0D"
        android:textSize="15dp"/>

    <Button
        android:id="@+id/fitness_cal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="120dp"
        android:layout_marginTop="320dp"
        android:text="Training Splits"/>



</FrameLayout>